{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SGSql",
  "version": "1.3.3",
  "identifier": "com.sgsql.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run icons:mac && bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "connection-manager",
        "url": "connection-manager.html",
        "title": "SGSql Connections",
        "width": 740,
        "height": 540,
        "resizable": true,
        "center": true,
        "decorations": true
      },
      {
        "label": "main",
        "title": "SGSql",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:7521 http://localhost:7522 http://localhost:7523 http://localhost:7524 http://localhost:7525 http://localhost:7526 http://localhost:7527 http://localhost:7528 http://localhost:7529 http://localhost:7530 http://localhost:45821 ws://localhost:45821; style-src 'self' 'unsafe-inline'; worker-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/dbsidecar"],
    "macOS": {
      "signingIdentity": "SGSql Developer",
      "hardenedRuntime": false
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/AppIcon.icon"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/stalingino/sgsql/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGODc0REJFQzIyOTg2RApSV1J0bUNMczIzVDRCcmh4OTFGWmwzU1RidUNxQndoa1hrc1pyRTBBcjNPWjZpME1FRzVpQkRqNQo="
    }
  }
}
