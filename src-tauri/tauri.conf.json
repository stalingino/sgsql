{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sgsql",
  "version": "0.1.0",
  "identifier": "com.sgsql.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "connection-manager",
        "url": "connection-manager.html",
        "title": "SG SQL Connections",
        "width": 740,
        "height": 540,
        "resizable": false,
        "center": true,
        "decorations": true
      },
      {
        "label": "main",
        "title": "SG SQL",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:7521 http://localhost:7522 http://localhost:7523 http://localhost:7524 http://localhost:7525 http://localhost:7526 http://localhost:7527 http://localhost:7528 http://localhost:7529 http://localhost:7530 http://localhost:45821; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/dbsidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
