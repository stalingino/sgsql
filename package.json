{
  "name": "sgsql",
  "private": true,
  "version": "1.3.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "bun test",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons:mac": "node scripts/build-macos-icons.mjs",
    "sidecar:build": "cargo build --release --manifest-path src-tauri/Cargo.toml -p dbsidecar --target aarch64-apple-darwin && cp src-tauri/target/aarch64-apple-darwin/release/dbsidecar src-tauri/binaries/dbsidecar-aarch64-apple-darwin && codesign --force --sign \"SGSql Developer\" src-tauri/binaries/dbsidecar-aarch64-apple-darwin",
    "sidecar:dev": "cargo run --manifest-path src-tauri/Cargo.toml -p dbsidecar"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
