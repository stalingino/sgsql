    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
