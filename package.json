    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@tailwindcss/vite": "^4.2.2",
